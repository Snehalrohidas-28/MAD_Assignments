<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 My Daily Diary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter file name (e.g. diary.txt)"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnCreate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create"
                android:backgroundTint="#4CAF50"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete"
                android:backgroundTint="#F44336"
                android:textColor="@android:color/white"
                android:layout_marginStart="10dp"/>
        </LinearLayout>


        <EditText
            android:id="@+id/etDiary"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="Write your thoughts..."
            android:gravity="top"
            android:padding="12dp"
            android:layout_marginTop="20dp"
            android:background="@android:drawable/edit_text"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save Entry"
                android:backgroundTint="#FF9800"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnRead"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Read Diary"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white"
                android:layout_marginStart="10dp"/>
        </LinearLayout>


        <TextView
            android:id="@+id/txtOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 Your stored memories will show here..."
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginTop="20dp"
            android:background="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
