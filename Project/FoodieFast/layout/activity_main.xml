
<androidx.drawerlayout.widget.DrawerLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/drawerLayout"
android:layout_width="match_parent"
android:layout_height="match_parent">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:orientation="vertical"
        android:background="#0F0F0F"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvHello"
                    android:text="Hello User 👋"
                    android:textColor="#FFA500"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What would you like to cook today?"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/ic_user"
                android:background="@drawable/bg_card"
                android:padding="8dp"/>
        </LinearLayout>


        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="Search Recipes..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888"
            android:background="@drawable/bg_input"
            android:padding="14dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catAll"
                    style="@style/categoryBtn"
                    android:text="All"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catBreakfast"
                    style="@style/categoryBtn"
                    android:text="Breakfast"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catLunch"
                    style="@style/categoryBtn"
                    android:text="Lunch"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catDinner"
                    style="@style/categoryBtn"
                    android:text="Dinner"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catSnacks"
                    style="@style/categoryBtn"
                    android:text="Snacks"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catDessert"
                    style="@style/categoryBtn"
                    android:text="Dessert"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catBeverages"
                    style="@style/categoryBtn"
                    android:text="Beverages"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catVeg"
                    style="@style/categoryBtn"
                    android:text="Vegetarian"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catNonVeg"
                    style="@style/categoryBtn"
                    android:text="Non-Veg"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catHealthy"
                    style="@style/categoryBtn"
                    android:text="Healthy"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/catFast"
                    style="@style/categoryBtn"
                    android:text="Fast Food"/>

            </LinearLayout>
        </HorizontalScrollView>


        <ListView
            android:id="@+id/listRecipes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:divider="#222"
            android:dividerHeight="10dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="#111"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:id="@+id/navHome"
                android:layout_weight="1"
                android:src="@drawable/baseline_home_24"/>

            <ImageView

                android:layout_height="wrap_content"
                android:id="@+id/navLike"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:src="@drawable/baseline_favorite_24"/>

            <ImageView
                android:layout_height="wrap_content"
                android:id="@+id/navSave"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_save"/>

            <ImageView
                android:id="@+id/navAdd"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/baseline_add_24"
                android:layout_margin="8dp"/>
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="right"
        android:background="@drawable/drawer_bg"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="Menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:text="Profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"/>

            <TextView
                android:text="Logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E53935"
                android:textSize="16sp"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

    </LinearLayout>


</androidx.drawerlayout.widget.DrawerLayout>
