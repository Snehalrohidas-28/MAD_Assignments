<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="*"
    android:padding="16dp">

    <TableRow>
        <TextView
            android:text="Product"
            android:textStyle="bold"
            android:padding="10dp"/>

        <TextView
            android:text="Price"
            android:textStyle="bold"
            android:padding="10dp"/>

        <TextView
            android:text="Quantity"
            android:textStyle="bold"
            android:padding="10dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Laptop" android:padding="10dp"/>
        <TextView android:text="50000" android:padding="10dp"/>
        <TextView android:text="2" android:padding="10dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Mobile" android:padding="10dp"/>
        <TextView android:text="20000" android:padding="10dp"/>
        <TextView android:text="5" android:padding="10dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Headphones" android:padding="10dp"/>
        <TextView android:text="1500" android:padding="10dp"/>
        <TextView android:text="10" android:padding="10dp"/>
    </TableRow>
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back"
        android:layout_x="100dp"
        android:layout_y="150dp"/>
</TableLayout>
