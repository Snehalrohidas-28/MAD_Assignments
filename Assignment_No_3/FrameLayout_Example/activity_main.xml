<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:src="@drawable/masala_dosa" />

    <ImageView
        android:layout_width="132dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center|top"
        android:src="@drawable/chocolate_mousse" />

    <ImageView
        android:layout_width="114dp"
        android:layout_height="190dp"
        android:layout_gravity="right|top"
        android:src="@drawable/garlic_bread" />

    <ImageView
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:src="@drawable/gulab_jamun" />

    <ImageView
        android:layout_width="122dp"
        android:layout_height="225dp"
        android:layout_gravity="center"
        android:src="@drawable/custard" />

    <ImageView
        android:layout_width="117dp"
        android:layout_height="wrap_content"
        android:layout_gravity="right|center"
        android:src="@drawable/kachori" />

    <ImageView
        android:layout_width="116dp"
        android:layout_height="198dp"
        android:layout_gravity="bottom"
        android:src="@drawable/cappuccino" />

    <ImageView
        android:layout_width="122dp"
        android:layout_height="190dp"
        android:layout_gravity="center|bottom"
        android:src="@drawable/idli" />

    <ImageView
        android:layout_width="115dp"
        android:layout_height="196dp"
        android:layout_gravity="right|bottom"
        android:src="@drawable/lassi" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_x="100dp"
        android:layout_y="150dp"
        android:text="Back" />
</FrameLayout>
